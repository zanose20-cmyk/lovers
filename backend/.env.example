# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/lovers

# Redis (for socket adapter + caching)
REDIS_URL=redis://redis:6379

# Firebase service account
# Option A: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./serviceAccountKey.json
# Option B: set individual values
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=30d

# Voice Engine: 'jitsi' (free, self-hosted) or 'agora' (paid)
VOICE_ENGINE=jitsi

# Jitsi (free alternative to Agora)
JITSI_SERVER=https://meet.jit.si
# For self-hosted Jitsi: http://jitsi:8888
# JITSI_JWT_SECRET=your_jitsi_jwt_secret

# Agora (only needed if VOICE_ENGINE=agora)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Logging
LOG_LEVEL=info
